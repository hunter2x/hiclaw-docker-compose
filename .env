# ============================================================
# HiClaw Docker Compose 环境变量
# 基于 hiclaw-install.sh 转换生成
# ============================================================

# --- 语言 ---
HICLAW_LANGUAGE=zh

# --- LLM 配置 ---
HICLAW_LLM_PROVIDER=openai-compat
HICLAW_DEFAULT_MODEL=qwen3.6-plus
HICLAW_LLM_API_KEY=your-api-key-here
HICLAW_OPENAI_BASE_URL=https://token-plan.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
HICLAW_EMBEDDING_MODEL=text-embedding-v4

# --- LLM 高级参数（可选） ---
# HICLAW_MODEL_CONTEXT_WINDOW=
# HICLAW_MODEL_MAX_TOKENS=
# HICLAW_MODEL_REASONING=
# HICLAW_MODEL_VISION=

# --- 管理员账户 ---
HICLAW_ADMIN_USER=hiclaw
HICLAW_ADMIN_PASSWORD=change-me-please

# --- 端口配置 ---
HICLAW_LOCAL_ONLY=1
HICLAW_PORT_GATEWAY=18080
HICLAW_PORT_CONSOLE=18001
HICLAW_PORT_ELEMENT_WEB=18088
HICLAW_PORT_MANAGER_CONSOLE=18888

# --- Manager 运行时 (openclaw | copaw) ---
HICLAW_MANAGER_RUNTIME=copaw

# --- Matrix ---
HICLAW_MATRIX_DOMAIN=matrix-local.hiclaw.io:18080
# HICLAW_MATRIX_CLIENT_DOMAIN=

# --- Matrix E2EE (0=禁用, 1=启用) ---
HICLAW_MATRIX_E2EE=0

# --- 网关域名 ---
HICLAW_AI_GATEWAY_DOMAIN=aigw-local.hiclaw.io
HICLAW_FS_DOMAIN=fs-local.hiclaw.io
HICLAW_CONSOLE_DOMAIN=console-local.hiclaw.io

# --- GitHub Token（可选） ---
# HICLAW_GITHUB_TOKEN=

# --- Nacos Worker 市场（可选） ---
# HICLAW_NACOS_REGISTRY_URI=nacos://market.hiclaw.io:80/public
# HICLAW_NACOS_USERNAME=
# HICLAW_NACOS_PASSWORD=
# HICLAW_NACOS_TOKEN=

# --- Skills Registry（可选） ---
# HICLAW_SKILLS_API_URL=nacos://market.hiclaw.io:80/public

# --- CMS/ARMS 可观测性（可选） ---
# HICLAW_CMS_TRACES_ENABLED=false
# HICLAW_CMS_ENDPOINT=
# HICLAW_CMS_LICENSE_KEY=
# HICLAW_CMS_PROJECT=
# HICLAW_CMS_WORKSPACE=
# HICLAW_CMS_SERVICE_NAME=hiclaw-manager
# HICLAW_CMS_METRICS_ENABLED=false

# --- Worker 默认运行时 (openclaw | copaw | hermes) ---
HICLAW_DEFAULT_WORKER_RUNTIME=openclaw

# --- Worker 空闲超时（分钟，默认 720 = 12小时） ---
HICLAW_WORKER_IDLE_TIMEOUT=720

# --- Docker API 代理 (0=禁用, 1=启用) ---
HICLAW_DOCKER_PROXY=1

# --- 镜像仓库（自动按地区选择） ---
# HICLAW_REGISTRY=

# --- 镜像版本 ---
HICLAW_VERSION=latest

# --- 数据持久化 ---
HICLAW_DATA_DIR=hiclaw-data

# --- 工作区目录（Manager 的 skills/memory/state 存储） ---
HICLAW_WORKSPACE_DIR=./hiclaw-manager-workspace

# --- 主机文件共享目录 ---
HICLAW_HOST_SHARE_DIR=${HOME}

# --- JVM 参数（Apple Silicon 修复 SIGILL） ---
# JVM_ARGS=

# --- YOLO 模式 ---
# HICLAW_YOLO=1

# --- Matrix Debug 追踪 ---
# HICLAW_MATRIX_DEBUG=1
